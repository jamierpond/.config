#!/usr/bin/env bash

search_dirs=(
    "$HOME"
    "$HOME/projects"
    "$HOME/projects/mayk-it"
    "$HOME/projects/TamberWorkspace"
    "$HOME/Music/NME/Project Files"
    /tmp/time
)

if [[ $# -eq 1 ]]; then
    selected=$1
else
    existing=()
    for d in "${search_dirs[@]}"; do
        [[ -d $d ]] && existing+=("$d")
    done
    selected=$(find "${existing[@]}" -mindepth 1 -maxdepth 1 -type d | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)

# No server running and not inside tmux: start fresh, attached
if [[ -z $TMUX ]] && ! tmux ls &> /dev/null; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

if [[ -z $TMUX ]]; then
    tmux attach -t "$selected_name"
else
    tmux switch-client -t "$selected_name"
fi
